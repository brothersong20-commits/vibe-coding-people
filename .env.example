# Supabase 프로젝트 키 — Phase 4.0 도입.
# 실제 값은 .env.local 에 채우고, .env.local 은 git 에 커밋되지 않는다.
# Vercel Project Settings → Environment Variables 에도 동일하게 등록한다.

# 공개 키 (브라우저/서버 모두에서 사용 가능)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-publishable-key"

# 비공개 키 — 서버 전용. 시드 스크립트와 향후 어드민 작업에서만 사용.
# 절대 NEXT_PUBLIC_ 접두어로 노출하지 않는다.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
